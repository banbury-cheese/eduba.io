# Auth.js (NextAuth) — required for Google sign-in on internal routes.
# Generate AUTH_SECRET locally: `openssl rand -base64 32`
AUTH_SECRET=

# Google OAuth client credentials.
# Create at https://console.cloud.google.com/apis/credentials
#   - Application type: Web application
#   - Authorized JavaScript origins: https://eduba.io , http://localhost:3000
#   - Authorized redirect URIs:
#       https://eduba.io/api/auth/callback/google
#       http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Sanity (optional — falls back to fallbackSectors if unset)
SANITY_PROJECT_ID=
SANITY_DATASET=
SANITY_API_VERSION=2023-08-01
SANITY_API_READ_TOKEN=
